{
  "manifest_version": 3,
  "name": "Ali Ürün Analiz V2",
  "version": "1.0",
  "permissions": ["tabs", "scripting", "storage", "activeTab"],
  "host_permissions": [
    "https://aliexpress.com/*",
    "https://*.aliexpress.com/*",
    "https://aliexpress.us/*",
    "https://*.aliexpress.us/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://aliexpress.com/*",
        "https://*.aliexpress.com/*",
        "https://aliexpress.us/*",
        "https://*.aliexpress.us/*"
      ],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["fullscreen.html", "fullscreen.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
